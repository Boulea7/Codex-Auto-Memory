{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Auto Memory Session Continuity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal",
    "confirmedWorking",
    "triedAndFailed",
    "notYetTried",
    "incompleteNext",
    "filesDecisionsEnvironment"
  ],
  "properties": {
    "sourceSessionId": {
      "type": "string"
    },
    "goal": {
      "type": "string",
      "maxLength": 400
    },
    "confirmedWorking": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 240
      }
    },
    "triedAndFailed": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 240
      }
    },
    "notYetTried": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 240
      }
    },
    "incompleteNext": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 240
      }
    },
    "filesDecisionsEnvironment": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 240
      }
    }
  }
}
