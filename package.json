{
  "name": "codex-auto-memory",
  "version": "0.1.0",
  "description": "Claude-style auto memory for Codex, implemented as a local companion CLI.",
  "type": "module",
  "bin": {
    "cam": "dist/cli.js"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist coverage .tmp",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "codex",
    "memory",
    "cli",
    "markdown",
    "automation"
  ],
  "author": "Boulea7",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Boulea7/Codex-Auto-Memory.git"
  },
  "bugs": {
    "url": "https://github.com/Boulea7/Codex-Auto-Memory/issues"
  },
  "homepage": "https://github.com/Boulea7/Codex-Auto-Memory#readme",
  "dependencies": {
    "commander": "^14.0.1",
    "smol-toml": "^1.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
